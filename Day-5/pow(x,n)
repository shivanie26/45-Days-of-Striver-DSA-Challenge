class Solution {
    public double myPow(double x, int n) {
          double ans=1;
          int power=n;
          if(power < 0) {
            power = -power;
        }

          for(int i=1;i<=power;i++){
            ans=ans*x;
          }
          if(n<0){
            ans=1/ans;
          }
          return ans;
    }
}
