class Solution {
    public boolean searchMatrix(int[][] mat, int target) {
    int a=mat.length;
    int b=mat[0].length;
    for(int i=0;i<a;i++){
        for(int j=0;j<b;j++){
            if(mat[i][j]== target){
                return true;
            }
        }
    }
    return false;
    }
}
